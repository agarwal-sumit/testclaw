{
  "name": "testclaw",
  "version": "0.1.0",
  "description": "AI-powered mobile app testing CLI using Claude Code Agent SDK",
  "type": "module",
  "bin": {
    "testclaw": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
